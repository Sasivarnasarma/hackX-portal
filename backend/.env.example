ENV_LOADED=true
ENVIRONMENT=development # set to 'production' to disable Swagger/ReDoc docs in production

# Database
DATABASE_URL=sqlite+aiosqlite:///hackx.db
DB_ECHO=false

# Auth Security
JWT_SECRET_KEY=generate_your_secure_random_key_here

# --- HackX University Tier (Primary Email Keys) ---
HACKX_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
HACKX_RESEND_FROM_EMAIL=registrations@hackx.lk
HACKX_FROM_NAME="HackX Committee"
HACKX_MAILTRAP_API_KEY=your_mailtrap_token_here
HACKX_MAILTRAP_FROM_EMAIL=registrations@hackx.lk

# --- HackX Jr School Tier (Primary Email Keys) ---
HACKXJR_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
HACKXJR_RESEND_FROM_EMAIL=registrations@jr.hackx.lk
HACKXJR_FROM_NAME="HackX Jr Committee"
HACKXJR_MAILTRAP_API_KEY=your_mailtrap_token_here
HACKXJR_MAILTRAP_FROM_EMAIL=registrations@jr.hackx.lk

# --- Shared Fallback Domain (Fallback Email Keys) ---
FALLBACK_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
FALLBACK_RESEND_FROM_EMAIL=registrations@hackxfallback.lk
FALLBACK_FROM_NAME="HackX Support"
FALLBACK_MAILTRAP_API_KEY=your_mailtrap_token_here
FALLBACK_MAILTRAP_FROM_EMAIL=registrations@hackxfallback.lk


# SMTP Credentials (e.g. Mailtrap Sandbox or Gmail SMTP)
SMTP_SERVER=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_smtp_username
SMTP_PASSWORD=your_mailtrap_smtp_password
SMTP_FROM_EMAIL=registrations@hackx.lk
SMTP_FROM_NAME="HackX Support"


# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000XX

# Telegram Notifications
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=123456789

# Google Sheets Configuration
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_OAUTH_TOKEN_B64=base64_encoded_oauth_token

# Email Dispatch Configurations
SEND_MAIL_TO_MEMBERS=false
SIMULATE_MAIL=false
